{
    "swagger": "2.0",
    "info": {
        "description": "边缘节点 HTTP API：终端 blob 分发、节点本地管理 API 与 Prometheus 指标。",
        "title": "MediaWorker Edge-Node API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/blob/{hash}": {
            "get": {
                "description": "根据 SHA-256 哈希值从缓存或对等节点获取 blob 内容并返回二进制流。",
                "produces": [
                    "application/octet-stream"
                ],
                "tags": [
                    "blob"
                ],
                "summary": "按哈希取 blob 字节流",
                "parameters": [
                    {
                        "type": "string",
                        "description": "blob SHA-256 哈希",
                        "name": "hash",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "file"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/metrics": {
            "get": {
                "description": "Prometheus 文本格式的运行指标，包括缓存命中、对等点请求等度量。",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "ops"
                ],
                "summary": "节点指标",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/v1/admin/flush-cache": {
            "post": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "接受 partition 列表（当前仅支持 \"warm\"），立即返回 202 并异步执行冲刷；并发的第二次 POST 由 singleflight 去重。",
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "冲刷缓存分区",
                "parameters": [
                    {
                        "description": "分区列表",
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/adminapi.flushRequest"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "$ref": "#/definitions/adminapi.flushResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/admin/reload-config": {
            "post": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "重新加载配置文件并应用可热更新的白名单字段（JWT 刷新间隔、管理令牌等），需要重启的字段返回 not_applied。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "热加载配置",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/config.ReloadReport"
                        }
                    },
                    "422": {
                        "description": "Unprocessable Entity",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/backhaul": {
            "get": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "返回带宽使用率、24h 成功率、P95 延迟、linkpool 命中率与网盘账号列表。非 L4 节点返回 409。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "回传链路状态",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/adminapi.backhaulResponse"
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/cache": {
            "get": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "返回 prefix（PinStore）、warm（WarmCache）分区用量、blob 数与驱逐计数器。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "缓存状态",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/adminapi.cacheResponse"
                        }
                    }
                }
            }
        },
        "/v1/healthz": {
            "get": {
                "description": "返回 {\"status\":\"ok\"} 表示节点管理 API 可正常响应。",
                "tags": [
                    "ops"
                ],
                "summary": "管理接口健康探测",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        },
        "/v1/network": {
            "get": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "返回监听地址、入站/出站连接数、DHT 路由表大小、GossipSub 订阅状态、NAT 可访问性与 hash ring 位置。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "网络状态",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/adminapi.networkResponse"
                        }
                    }
                }
            }
        },
        "/v1/peers": {
            "get": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "返回 peerstore 中所有已知对等点的身份、能力、评分、过期状态与最近活跃时间。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "对等点列表",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/adminapi.peerView"
                            }
                        }
                    }
                }
            }
        },
        "/v1/pin-plans/recent": {
            "get": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "返回 syncbroadcaster 最近收到的 PinPlan 记录，可选 limit 参数限制条数。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "最近的钉扎计划",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "返回条数上限",
                        "name": "limit",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/planlog.Record"
                            }
                        }
                    }
                }
            }
        },
        "/v1/pins": {
            "get": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "返回已钉扎的 blob 条目，支持按 role、content_id、ready 过滤。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "钉扎列表",
                "parameters": [
                    {
                        "type": "string",
                        "description": "按角色过滤",
                        "name": "role",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "按内容 ID 过滤",
                        "name": "content_id",
                        "in": "query"
                    },
                    {
                        "type": "boolean",
                        "description": "按就绪状态过滤",
                        "name": "ready",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/adminapi.pinsResponse"
                        }
                    }
                }
            }
        },
        "/v1/pins/{hash}/retry": {
            "post": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "将指定 blob 哈希对应的失败钉扎项重新加入拉取队列。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "重试钉扎",
                "parameters": [
                    {
                        "type": "string",
                        "description": "blob SHA-256 哈希",
                        "name": "hash",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/v1/status": {
            "get": {
                "security": [
                    {
                        "AdminToken": []
                    }
                ],
                "description": "返回节点身份、能力、JWT 状态、连接数、缓存命中率与 TTFB P95。",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "node-admin"
                ],
                "summary": "节点状态",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/adminapi.statusResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "adminapi.backhaulAccount": {
            "type": "object",
            "properties": {
                "backend_id": {
                    "type": "string"
                },
                "circuit": {
                    "type": "string"
                },
                "health": {
                    "type": "string"
                },
                "inflight": {
                    "type": "integer"
                },
                "qps": {
                    "$ref": "#/definitions/adminapi.backhaulQPS"
                }
            }
        },
        "adminapi.backhaulBandwidth": {
            "type": "object",
            "properties": {
                "capacity_bps": {
                    "type": "integer"
                },
                "used_bps": {
                    "type": "number"
                }
            }
        },
        "adminapi.backhaulLinkpool": {
            "type": "object",
            "properties": {
                "entries": {
                    "type": "integer"
                },
                "hit_rate": {
                    "type": "number"
                }
            }
        },
        "adminapi.backhaulQPS": {
            "type": "object",
            "properties": {
                "limit": {
                    "type": "number"
                },
                "used": {
                    "type": "number"
                }
            }
        },
        "adminapi.backhaulResponse": {
            "type": "object",
            "properties": {
                "accounts": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/adminapi.backhaulAccount"
                    }
                },
                "bandwidth": {
                    "$ref": "#/definitions/adminapi.backhaulBandwidth"
                },
                "latency_p95_ms": {
                    "type": "integer"
                },
                "linkpool": {
                    "$ref": "#/definitions/adminapi.backhaulLinkpool"
                },
                "success_rate_24h": {
                    "type": "number"
                }
            }
        },
        "adminapi.cacheHitRates": {
            "type": "object",
            "properties": {
                "prefix": {
                    "type": "number"
                },
                "warm": {
                    "type": "number"
                }
            }
        },
        "adminapi.cachePartition": {
            "type": "object",
            "properties": {
                "blob_count": {
                    "type": "integer"
                },
                "total": {
                    "type": "integer"
                },
                "used": {
                    "type": "integer"
                }
            }
        },
        "adminapi.cacheResponse": {
            "type": "object",
            "properties": {
                "cold": {},
                "eviction_counters": {
                    "$ref": "#/definitions/adminapi.evictionCounter"
                },
                "prefix": {
                    "$ref": "#/definitions/adminapi.cachePartition"
                },
                "warm": {
                    "$ref": "#/definitions/adminapi.cachePartition"
                }
            }
        },
        "adminapi.connBreakdown": {
            "type": "object",
            "properties": {
                "in": {
                    "type": "integer"
                },
                "out": {
                    "type": "integer"
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "adminapi.connStats": {
            "type": "object",
            "properties": {
                "inbound": {
                    "type": "integer"
                },
                "outbound": {
                    "type": "integer"
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "adminapi.dhtStatus": {
            "type": "object",
            "properties": {
                "mode": {
                    "type": "string"
                },
                "table_size": {
                    "type": "integer"
                }
            }
        },
        "adminapi.evictionCounter": {
            "type": "object",
            "properties": {
                "cold_1h": {
                    "type": "integer"
                },
                "warm_1h": {
                    "type": "integer"
                }
            }
        },
        "adminapi.flushRequest": {
            "type": "object",
            "properties": {
                "partitions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                }
            }
        },
        "adminapi.flushResponse": {
            "type": "object",
            "properties": {
                "partitions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "status": {
                    "type": "string"
                }
            }
        },
        "adminapi.gossipsubStatus": {
            "type": "object",
            "properties": {
                "subscribed": {
                    "description": "static true: the topic is joined during assembly",
                    "type": "boolean"
                }
            }
        },
        "adminapi.hashRingStatus": {
            "type": "object",
            "properties": {
                "peers_on_ring": {
                    "type": "integer"
                },
                "position_pct": {
                    "description": "null when self is absent from the ring",
                    "type": "number"
                }
            }
        },
        "adminapi.jwtStatus": {
            "type": "object",
            "properties": {
                "exp": {
                    "description": "null when no verifiable JWT",
                    "type": "integer"
                },
                "last_refresh_at": {
                    "description": "null when never attempted",
                    "type": "string"
                },
                "last_refresh_ok": {
                    "type": "boolean"
                },
                "refresh_before": {
                    "type": "integer"
                },
                "refresh_fail_count_24h": {
                    "type": "integer"
                }
            }
        },
        "adminapi.natStatus": {
            "type": "object",
            "properties": {
                "dcutr_counters_unavailable": {
                    "type": "boolean"
                },
                "dcutr_success_rate": {
                    "type": "number"
                },
                "reachability": {
                    "type": "string"
                },
                "relay_circuits": {
                    "type": "integer"
                }
            }
        },
        "adminapi.networkResponse": {
            "type": "object",
            "properties": {
                "conn": {
                    "$ref": "#/definitions/adminapi.connBreakdown"
                },
                "dht": {
                    "$ref": "#/definitions/adminapi.dhtStatus"
                },
                "gossipsub": {
                    "$ref": "#/definitions/adminapi.gossipsubStatus"
                },
                "hash_ring": {
                    "$ref": "#/definitions/adminapi.hashRingStatus"
                },
                "listen_addrs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "nat": {
                    "$ref": "#/definitions/adminapi.natStatus"
                }
            }
        },
        "adminapi.peerView": {
            "type": "object",
            "properties": {
                "addrs": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "capabilities": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "last_seen": {
                    "type": "integer"
                },
                "peer_id": {
                    "type": "string"
                },
                "score": {
                    "type": "number"
                },
                "stale": {
                    "type": "boolean"
                }
            }
        },
        "adminapi.pinEntry": {
            "type": "object",
            "properties": {
                "blob_hash": {
                    "type": "string"
                },
                "content_id": {
                    "type": "string"
                },
                "last_error": {
                    "type": "string"
                },
                "pinned_at": {
                    "type": "string"
                },
                "role": {
                    "type": "string"
                },
                "size": {
                    "type": "integer"
                },
                "state": {
                    "type": "string"
                }
            }
        },
        "adminapi.pinSummary": {
            "type": "object",
            "properties": {
                "failed": {
                    "type": "integer"
                },
                "pulling": {
                    "type": "integer"
                },
                "ready": {
                    "type": "integer"
                },
                "total": {
                    "type": "integer"
                }
            }
        },
        "adminapi.pinsResponse": {
            "type": "object",
            "properties": {
                "pins": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/adminapi.pinEntry"
                    }
                },
                "summary": {
                    "$ref": "#/definitions/adminapi.pinSummary"
                }
            }
        },
        "adminapi.scoreView": {
            "type": "object",
            "properties": {
                "graylisted_peers": {
                    "type": "integer"
                }
            }
        },
        "adminapi.statusResponse": {
            "type": "object",
            "properties": {
                "cache_hit_rate": {
                    "$ref": "#/definitions/adminapi.cacheHitRates"
                },
                "capabilities": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "conn": {
                    "$ref": "#/definitions/adminapi.connStats"
                },
                "healthy": {
                    "type": "boolean"
                },
                "jwt": {
                    "$ref": "#/definitions/adminapi.jwtStatus"
                },
                "mode": {
                    "description": "\"l4\" | \"edge\"",
                    "type": "string"
                },
                "peer_id": {
                    "type": "string"
                },
                "region": {
                    "type": "string"
                },
                "relay_bytes_24h": {
                    "type": "integer"
                },
                "score_view": {
                    "$ref": "#/definitions/adminapi.scoreView"
                },
                "ttfb_p95_ms": {
                    "type": "integer"
                },
                "uptime_sec": {
                    "type": "integer"
                },
                "version": {
                    "type": "string"
                }
            }
        },
        "config.ReloadNotApplied": {
            "type": "object",
            "properties": {
                "field": {
                    "type": "string"
                },
                "reason": {
                    "type": "string"
                }
            }
        },
        "config.ReloadReport": {
            "type": "object",
            "properties": {
                "applied": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "not_applied": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/config.ReloadNotApplied"
                    }
                }
            }
        },
        "planlog.Record": {
            "type": "object",
            "properties": {
                "applied": {
                    "description": "false when the pin store is disabled (prefix cache off)",
                    "type": "boolean"
                },
                "pins": {
                    "type": "integer"
                },
                "received_at": {
                    "type": "string"
                },
                "seq": {
                    "type": "integer"
                },
                "unpins": {
                    "type": "integer"
                }
            }
        },
        "types.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "AdminToken": {
            "description": "节点本地管理 API 令牌",
            "type": "apiKey",
            "name": "X-Admin-Token",
            "in": "header"
        }
    }
}