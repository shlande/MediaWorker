{
    "swagger": "2.0",
    "info": {
        "description": "入库 Worker HTTP API：multipart 内容上传入库、存活探针与 Prometheus 指标。",
        "title": "MediaWorker Ingest-Worker API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/healthz": {
            "get": {
                "description": "返回 200 \"ok\"，供 Kubernetes liveness/readiness 探针使用。",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "ops"
                ],
                "summary": "存活探针",
                "responses": {
                    "200": {
                        "description": "ok",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/ingest/{content_type}": {
            "post": {
                "description": "接收 multipart/form-data 文件上传，经 ingest pipeline 处理后入库到云盘并写入元数据。",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ingest"
                ],
                "summary": "multipart 上传内容并入库",
                "parameters": [
                    {
                        "type": "string",
                        "description": "内容类型（dash_video|image）",
                        "name": "content_type",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "上传文件",
                        "name": "file",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "JSON 元数据（ingest.ProcessOptions.Metadata）",
                        "name": "metadata",
                        "in": "formData"
                    },
                    {
                        "type": "string",
                        "description": "指定内容 ID",
                        "name": "content_id",
                        "in": "formData"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/ingest.IngestResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    },
                    "405": {
                        "description": "Method Not Allowed",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/types.ErrorResponse"
                        }
                    }
                }
            }
        },
        "/metrics": {
            "get": {
                "description": "返回 Prometheus 文本格式指标，抓取前刷新 ingest_publish_failures 计数。",
                "produces": [
                    "text/plain"
                ],
                "tags": [
                    "ops"
                ],
                "summary": "Prometheus 指标",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "ingest.IngestResponse": {
            "type": "object",
            "properties": {
                "content_id": {
                    "type": "string"
                }
            }
        },
        "types.ErrorResponse": {
            "type": "object",
            "properties": {
                "error": {
                    "type": "string"
                }
            }
        }
    },
    "tags": [
        {
            "description": "内容上传入库",
            "name": "ingest"
        },
        {
            "description": "运维与指标",
            "name": "ops"
        }
    ]
}